@inherits LayoutComponentBase
@implements IDisposable

<div class="@(_isDarkMode ? "dark" : "light")">
<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="0" Class="sidebar-gradient">

        <div class="sidebar-logo">
            <MudIcon Icon="@Icons.Material.Outlined.SwapHoriz"
                     Style="color: rgba(255,255,255,0.9); font-size: 28px;" />
            <span class="sidebar-logo-text">Migrify</span>
        </div>

        <MudNavMenu Class="px-2">
            <MudNavLink Href="/" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Outlined.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/projects" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Outlined.Folder">Projects</MudNavLink>
            <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Outlined.Settings">Settings</MudNavLink>
        </MudNavMenu>

        <MudSpacer />

        <div class="sidebar-bottom">
            <div class="d-flex align-center mb-1">
                <MudIcon Icon="@Icons.Material.Outlined.AccessTime" Size="Size.Small" Class="mr-2"
                         Style="color: rgba(255,255,255,0.45);" />
                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.45);">@_serverTime</MudText>
            </div>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Class="mr-2"
                         Style="color: rgba(255,255,255,0.45);" />
                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.45);">v@(AppVersion)</MudText>
            </div>
            <div class="sidebar-bottom-actions">
                <MudTooltip Text="@(_isDarkMode ? "Light theme" : "Dark theme")">
                    <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                                   Size="Size.Small" Style="color: rgba(255,255,255,0.7);"
                                   OnClick="ToggleTheme" />
                </MudTooltip>
                <AuthorizeView>
                    <Authorized>
                        <MudTooltip Text="Sign out">
                            <form method="post" action="/api/account/logout">
                                <AntiforgeryToken />
                                <MudIconButton Icon="@Icons.Material.Outlined.Logout"
                                               Size="Size.Small" Style="color: rgba(255,255,255,0.7);"
                                               ButtonType="ButtonType.Submit" />
                            </form>
                        </MudTooltip>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </MudDrawer>

    <MudMainContent>
        <div class="content-area">
            <MudContainer MaxWidth="MaxWidth.Large" Class="pa-0">
                @Body
            </MudContainer>
        </div>
    </MudMainContent>
</MudLayout>
</div>

@code {
    public const string AppVersion = "0.1.0";

    private bool _isDarkMode = true;
    private string _serverTime = "";
    private Timer? _timer;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#6366F1",
            Secondary = "#8B5CF6",
            Tertiary = "#A78BFA",
            Error = "#EF4444",
            Success = "#10B981",
            Warning = "#F59E0B",
            Info = "#3B82F6",
            Background = "#F8F9FB",
            Surface = "#FFFFFF",
            TextPrimary = "#111827",
            TextSecondary = "#6B7280",
            TextDisabled = "#D1D5DB",
            ActionDefault = "#6B7280",
            ActionDisabled = "#D1D5DB",
            LinesDefault = "#E5E7EB",
            LinesInputs = "#D1D5DB",
            TableLines = "#F3F4F6",
            Divider = "#E5E7EB",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#374151",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#111827"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#818CF8",
            Secondary = "#A78BFA",
            Tertiary = "#C4B5FD",
            Error = "#F87171",
            Success = "#34D399",
            Warning = "#FBBF24",
            Info = "#60A5FA",
            Background = "#0F1117",
            Surface = "#1A1D27",
            TextPrimary = "#F3F4F6",
            TextSecondary = "#9CA3AF",
            TextDisabled = "#4B5563",
            ActionDefault = "#9CA3AF",
            ActionDisabled = "#374151",
            LinesDefault = "#2A2D3A",
            LinesInputs = "#363946",
            TableLines = "#1F2230",
            Divider = "#2A2D3A",
            DrawerBackground = "#141720",
            DrawerText = "#D1D5DB",
            AppbarBackground = "#141720",
            AppbarText = "#F3F4F6"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Inter", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" }
            },
            H1 = new H1Typography { FontWeight = "700", FontSize = "2.25rem", LetterSpacing = "-0.02em" },
            H2 = new H2Typography { FontWeight = "700", FontSize = "1.875rem", LetterSpacing = "-0.02em" },
            H3 = new H3Typography { FontWeight = "700", FontSize = "1.5rem", LetterSpacing = "-0.01em" },
            H4 = new H4Typography { FontWeight = "700", FontSize = "1.25rem", LetterSpacing = "-0.01em" },
            H5 = new H5Typography { FontWeight = "600", FontSize = "1.125rem" },
            H6 = new H6Typography { FontWeight = "600", FontSize = "1rem" },
            Subtitle1 = new Subtitle1Typography { FontWeight = "500", FontSize = "0.9375rem" },
            Subtitle2 = new Subtitle2Typography { FontWeight = "500", FontSize = "0.8125rem" },
            Body1 = new Body1Typography { FontSize = "0.9375rem", LineHeight = "1.6" },
            Body2 = new Body2Typography { FontSize = "0.8125rem", LineHeight = "1.5" },
            Button = new ButtonTypography { FontWeight = "600", FontSize = "0.875rem", LetterSpacing = "0", TextTransform = "none" },
            Caption = new CaptionTypography { FontSize = "0.75rem", FontWeight = "500" },
            Overline = new OverlineTypography { FontSize = "0.6875rem", FontWeight = "600", LetterSpacing = "0.08em" }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px",
            DrawerWidthLeft = "260px",
            AppbarHeight = "0px"
        }
    };

    protected override void OnInitialized()
    {
        UpdateServerTime();
        _timer = new Timer(_ => InvokeAsync(() =>
        {
            UpdateServerTime();
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void UpdateServerTime()
    {
        _serverTime = DateTime.Now.ToString("dd-MM-yyyy HH:mm:ss");
    }

    private void ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
