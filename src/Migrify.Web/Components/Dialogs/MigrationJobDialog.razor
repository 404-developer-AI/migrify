@inject IMigrationJobRepository JobRepository
@inject ICredentialEncryptor CredentialEncryptor
@inject IImapConnectionTester ImapTester
@inject IImapAutoDiscoveryService ImapDiscovery
@inject IOAuthTokenService OAuthTokenService
@inject IImapOAuthCredentialProvider OAuthCredentialProvider
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEditMode ? "Edit Migration Job" : "New Migration Job")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true">
            <MudTabPanel Text="General" Icon="@Icons.Material.Filled.Info">
                @if (ProjectSourceConnectorType == SourceConnectorType.GoogleWorkspace && SourceMailboxes.Count > 0)
                {
                    <MudAutocomplete T="string" @bind-Value="_sourceEmail" Label="Source Email" Required="true"
                                     RequiredError="Source email is required"
                                     SearchFunc="SearchSourceMailboxes"
                                     CoerceValue="false"
                                     Placeholder="Search or type email..." Class="mb-3" />
                }
                else
                {
                    <MudTextField @bind-Value="_sourceEmail" Label="Source Email" Required="true"
                                  RequiredError="Source email is required"
                                  Placeholder="user@source-domain.com" Class="mb-3" />
                }

                @if (DestinationMailboxes.Count > 0)
                {
                    <MudAutocomplete T="string" @bind-Value="_destinationEmail" Label="Destination Email" Required="true"
                                     RequiredError="Destination email is required"
                                     SearchFunc="SearchDestinationMailboxes"
                                     CoerceValue="false"
                                     Placeholder="Search or type email..." Class="mb-3" />
                }
                else
                {
                    <MudTextField @bind-Value="_destinationEmail" Label="Destination Email" Required="true"
                                  RequiredError="Destination email is required"
                                  Placeholder="user@destination-domain.com" Class="mb-3" />
                }

                @if (ProjectSourceConnectorType == SourceConnectorType.GoogleWorkspace)
                {
                    <MudSwitch @bind-Value="_hasImapOverride" Label="Use custom IMAP credentials for this job"
                               Color="Color.Warning" Class="mt-2" />
                    @if (!_hasImapOverride)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                            This job will use the project's Google Workspace connector for source access.
                        </MudAlert>
                    }
                }
            </MudTabPanel>

            @if (_showImapTab)
            {
                <MudTabPanel Text="IMAP Source" Icon="@Icons.Material.Filled.Email">
                    <MudTextField @bind-Value="_imapUsername" Label="Email Address"
                                  Placeholder="user@example.com" Class="mb-3" />

                    @if (_imapAuthType == ImapAuthType.Password)
                    {
                        <MudTextField @bind-Value="_imapPassword" Label="Password"
                                      InputType="InputType.Password"
                                      Placeholder="@(IsEditMode && _hasExistingImapPassword ? "Leave empty to keep current password" : "")"
                                      Class="mb-3" />
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                            OAuth2 lets you connect without sharing your password.
                            You need a Google Cloud project with OAuth2 credentials.
                        </MudAlert>

                        <MudExpansionPanels Elevation="0" Class="mb-3">
                            <MudExpansionPanel Text="How to set up Google OAuth2" MaxHeight="500">
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <strong>1.</strong> Go to <strong>Google Cloud Console</strong> > <strong>APIs & Services</strong> > <strong>Library</strong> > Enable <strong>Gmail API</strong>
                                </MudText>
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <strong>2.</strong> Go to <strong>OAuth consent screen</strong> > Choose <em>External</em> (or <em>Internal</em> for Workspace)
                                </MudText>
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <strong>3.</strong> Add scope: <code>https://mail.google.com/</code>
                                </MudText>
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <strong>4.</strong> Go to <strong>Credentials</strong> > <strong>Create Credentials</strong> > <strong>OAuth client ID</strong> > <em>Web application</em>
                                </MudText>
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <strong>5.</strong> Set redirect URI: <code>https://&lt;your-host&gt;/oauth/callback/google</code>
                                </MudText>
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <strong>6.</strong> Copy <strong>Client ID</strong> and <strong>Client Secret</strong> into the fields below
                                </MudText>
                                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                                    For full setup details, see <code>docs/google-oauth2-setup.md</code> in the Migrify repository.
                                </MudAlert>
                            </MudExpansionPanel>
                        </MudExpansionPanels>

                        <MudText Typo="Typo.caption" Class="mb-2">Supported OAuth2 Providers</MudText>
                        <MudChipSet T="string" ReadOnly="true" Class="mb-3">
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled">Google / Gmail</MudChip>
                            <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Disabled="true">Microsoft (coming soon)</MudChip>
                            <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Disabled="true">Yahoo (coming soon)</MudChip>
                        </MudChipSet>

                        <MudTextField @bind-Value="_oauthClientId" Label="Google Client ID"
                                      HelperText="From Google Cloud Console > APIs & Services > Credentials"
                                      Class="mb-3" />
                        <MudTextField @bind-Value="_oauthClientSecret" Label="Google Client Secret"
                                      InputType="InputType.Password"
                                      Placeholder="@(IsEditMode && _hasExistingOAuthClientSecret ? "Leave empty to keep current secret" : "")"
                                      Class="mb-3" />

                        <div class="d-flex align-center gap-3 mb-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Link"
                                       OnClick="StartOAuthAuthorization"
                                       Disabled="_isAuthorizing || string.IsNullOrWhiteSpace(_oauthClientId)">
                                @if (_isAuthorizing)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Authorizing...</span>
                                }
                                else
                                {
                                    <span>Authorize with Google</span>
                                }
                            </MudButton>

                            @if (_hasOAuthTokens)
                            {
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">
                                    Authorized
                                    @if (_oauthTokenExpiry.HasValue)
                                    {
                                        <text> — token expires @_oauthTokenExpiry.Value.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</text>
                                    }
                                </MudChip>
                            }
                        </div>
                    }

                    <MudButton Variant="Variant.Outlined" Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.AutoFixHigh"
                               OnClick="AutoDetectImapSettings" Disabled="_isAutoDetecting"
                               Class="mb-3">
                        @if (_isAutoDetecting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Detecting...</span>
                        }
                        else
                        {
                            <span>Auto-detect Settings</span>
                        }
                    </MudButton>

                    <MudSwitch @bind-Value="_showAdvancedImap" Label="Advanced Settings"
                               Color="Color.Primary" Class="mb-3" />
                    <MudCollapse Expanded="_showAdvancedImap">
                        <MudTextField @bind-Value="_imapHost" Label="IMAP Host" Placeholder="imap.example.com" Class="mb-3" />
                        <MudNumericField @bind-Value="_imapPort" Label="Port" Min="1" Max="65535" Class="mb-3" />
                        <MudSelect @bind-Value="_imapEncryption" Label="Encryption" Class="mb-3">
                            @foreach (var enc in Enum.GetValues<ImapEncryption>())
                            {
                                <MudSelectItem Value="@enc">@enc</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect @bind-Value="_imapAuthType" Label="Authentication" Class="mb-3">
                            @foreach (var auth in Enum.GetValues<ImapAuthType>())
                            {
                                <MudSelectItem Value="@auth">@auth</MudSelectItem>
                            }
                        </MudSelect>
                    </MudCollapse>

                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Cable"
                               OnClick="TestImapConnection" Disabled="_isTestingImap">
                        @if (_isTestingImap)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Testing...</span>
                        }
                        else
                        {
                            <span>Test Connection</span>
                        }
                    </MudButton>
                </MudTabPanel>
            }

            <MudTabPanel Text="Migration Options" Icon="@Icons.Material.Filled.Tune">
                <MudText Typo="Typo.subtitle2" Class="mb-3">Migration Mode</MudText>
                <MudRadioGroup @bind-Value="_migrationMode">
                    <MudRadio Value="MigrationMode.Copy" Color="Color.Primary">
                        Copy — Migrate all messages
                    </MudRadio>
                    <MudRadio Value="MigrationMode.Incremental" Color="Color.Primary">
                        Incremental — Skip messages already in destination
                    </MudRadio>
                </MudRadioGroup>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.subtitle2" Class="mb-3">Date Range Filter</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                    Only migrate emails within this date range. Leave empty to migrate all.
                    Uses received date (sent date for Sent Items).
                </MudText>
                <MudGrid>
                    <MudItem xs="6">
                        <MudDatePicker @bind-Date="_dateFrom" Label="From Date" Clearable="true"
                                       DateFormat="dd-MM-yyyy" Placeholder="No start date" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudDatePicker @bind-Date="_dateTo" Label="To Date" Clearable="true"
                                       DateFormat="dd-MM-yyyy" Placeholder="No end date" />
                    </MudItem>
                </MudGrid>
                @if (_migrationMode == MigrationMode.Incremental && ExistingJob?.LastCompletedAt.HasValue == true && !_dateFrom.HasValue)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        DateFrom will automatically use last completed run (@ExistingJob.LastCompletedAt.Value.ToLocalTime().ToString("dd-MM-yyyy HH:mm")).
                        Set a custom date above to override.
                    </MudAlert>
                }

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.subtitle2" Class="mb-3">Duplicate Handling</MudText>
                <MudSwitch @bind-Value="_skipDuplicates"
                           Label="Skip duplicate messages (check Message-ID)"
                           Color="Color.Primary"
                           Disabled="_migrationMode == MigrationMode.Incremental" />
                @if (_migrationMode == MigrationMode.Incremental)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        Incremental mode always checks for duplicates.
                    </MudAlert>
                }
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(IsEditMode ? "Update" : "Create")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public Guid ProjectId { get; set; }

    [Parameter]
    public MigrationJob? ExistingJob { get; set; }

    [Parameter]
    public SourceConnectorType ProjectSourceConnectorType { get; set; } = SourceConnectorType.ManualImap;

    [Parameter]
    public List<DiscoveredMailbox> SourceMailboxes { get; set; } = new();

    [Parameter]
    public List<DiscoveredMailbox> DestinationMailboxes { get; set; } = new();

    private bool IsEditMode => ExistingJob is not null;
    private bool _showImapTab => ProjectSourceConnectorType == SourceConnectorType.ManualImap || _hasImapOverride;

    // General
    private string _sourceEmail = string.Empty;
    private string _destinationEmail = string.Empty;
    private bool _hasImapOverride;

    // IMAP
    private string _imapHost = string.Empty;
    private int _imapPort = 993;
    private ImapEncryption _imapEncryption = ImapEncryption.SSL;
    private ImapAuthType _imapAuthType = ImapAuthType.Password;
    private string? _imapUsername;
    private string? _imapPassword;
    private bool _hasExistingImapPassword;
    private bool _isTestingImap;
    private bool _showAdvancedImap;
    private bool _isAutoDetecting;

    // OAuth2
    private string? _oauthClientId;
    private string? _oauthClientSecret;
    private bool _hasExistingOAuthClientSecret;
    private bool _hasOAuthTokens;
    private DateTime? _oauthTokenExpiry;
    private bool _isAuthorizing;
    private DotNetObjectReference<MigrationJobDialog>? _dotNetRef;

    // Migration options
    private MigrationMode _migrationMode = MigrationMode.Copy;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private bool _skipDuplicates = true;

    private bool _isSaving;

    protected override void OnParametersSet()
    {
        if (ExistingJob is not null)
        {
            _sourceEmail = ExistingJob.SourceEmail;
            _destinationEmail = ExistingJob.DestinationEmail;
            _hasImapOverride = ExistingJob.HasImapOverride;

            // Migration options
            _migrationMode = ExistingJob.MigrationMode;
            _dateFrom = ExistingJob.DateFrom;
            _dateTo = ExistingJob.DateTo;
            _skipDuplicates = ExistingJob.SkipDuplicates;

            if (ExistingJob.ImapSettings is not null)
            {
                var imap = ExistingJob.ImapSettings;
                _imapHost = imap.Host;
                _imapPort = imap.Port;
                _imapEncryption = imap.Encryption;
                _imapAuthType = imap.AuthType;
                _imapUsername = imap.Username;
                _hasExistingImapPassword = !string.IsNullOrEmpty(imap.EncryptedPassword);
                _showAdvancedImap = !string.IsNullOrEmpty(imap.Host);

                // OAuth2
                _oauthClientId = imap.OAuthClientId;
                _hasExistingOAuthClientSecret = !string.IsNullOrEmpty(imap.EncryptedOAuthClientSecret);
                _hasOAuthTokens = !string.IsNullOrEmpty(imap.EncryptedOAuthRefreshToken);
                _oauthTokenExpiry = imap.OAuthTokenExpiresAtUtc;
            }
        }
    }

    private Task<IEnumerable<string>> SearchSourceMailboxes(string? value, CancellationToken ct)
    {
        var results = SourceMailboxes
            .Where(m => string.IsNullOrEmpty(value)
                || m.Email.Contains(value, StringComparison.OrdinalIgnoreCase)
                || (m.DisplayName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false))
            .Select(m => m.Email)
            .Take(20);
        return Task.FromResult(results);
    }

    private Task<IEnumerable<string>> SearchDestinationMailboxes(string? value, CancellationToken ct)
    {
        var results = DestinationMailboxes
            .Where(m => string.IsNullOrEmpty(value)
                || m.Email.Contains(value, StringComparison.OrdinalIgnoreCase)
                || (m.DisplayName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false))
            .Select(m => m.Email)
            .Take(20);
        return Task.FromResult(results);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("migrifyOAuth.registerCallback", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnOAuthCallback(bool success, string jobId, string error)
    {
        if (success)
        {
            if (ExistingJob is not null)
            {
                var updated = await JobRepository.GetByIdAsync(ExistingJob.Id);
                if (updated?.ImapSettings is not null && ExistingJob.ImapSettings is not null)
                {
                    _hasOAuthTokens = !string.IsNullOrEmpty(updated.ImapSettings.EncryptedOAuthRefreshToken);
                    _oauthTokenExpiry = updated.ImapSettings.OAuthTokenExpiresAtUtc;
                    ExistingJob.ImapSettings.EncryptedOAuthAccessToken = updated.ImapSettings.EncryptedOAuthAccessToken;
                    ExistingJob.ImapSettings.EncryptedOAuthRefreshToken = updated.ImapSettings.EncryptedOAuthRefreshToken;
                    ExistingJob.ImapSettings.OAuthTokenExpiresAtUtc = updated.ImapSettings.OAuthTokenExpiresAtUtc;
                    ExistingJob.ImapSettings.OAuthProvider = updated.ImapSettings.OAuthProvider;
                }
            }

            Snackbar.Add("Google account authorized successfully!", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Authorization failed: {error}", Severity.Error);
        }

        _isAuthorizing = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task StartOAuthAuthorization()
    {
        if (string.IsNullOrWhiteSpace(_oauthClientId))
        {
            Snackbar.Add("Please enter a Google Client ID first.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_sourceEmail))
        {
            Snackbar.Add("Please enter a source email first.", Severity.Warning);
            return;
        }

        _isAuthorizing = true;
        StateHasChanged();

        try
        {
            await SaveOAuthCredentialsToJob();

            var redirectUri = $"{NavigationManager.BaseUri.TrimEnd('/')}/oauth/callback/google";
            var jobId = ExistingJob?.Id ?? Guid.Empty;

            if (jobId == Guid.Empty)
            {
                Snackbar.Add("Job must be saved before authorizing. Creating job...", Severity.Info);
                await Save();
                return;
            }

            var authUrl = OAuthTokenService.GetAuthorizationUrl(jobId, _oauthClientId, redirectUri);
            await JS.InvokeVoidAsync("migrifyOAuth.openPopup", authUrl);
        }
        catch (Exception ex)
        {
            _isAuthorizing = false;
            Snackbar.Add($"Error starting authorization: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveOAuthCredentialsToJob()
    {
        if (ExistingJob is null) return;

        ExistingJob.ImapSettings ??= new ImapSettings();
        ExistingJob.ImapSettings.OAuthClientId = _oauthClientId;
        ExistingJob.ImapSettings.OAuthProvider = "Google";
        ExistingJob.ImapSettings.AuthType = ImapAuthType.OAuth2;

        if (!string.IsNullOrEmpty(_oauthClientSecret))
        {
            ExistingJob.ImapSettings.EncryptedOAuthClientSecret = CredentialEncryptor.Encrypt(_oauthClientSecret);
            _hasExistingOAuthClientSecret = true;
        }

        await JobRepository.UpdateAsync(ExistingJob);
    }

    private async Task AutoDetectImapSettings()
    {
        if (string.IsNullOrWhiteSpace(_imapUsername) || !_imapUsername.Contains('@'))
        {
            Snackbar.Add("Please enter a valid email address first.", Severity.Warning);
            return;
        }

        _isAutoDetecting = true;
        StateHasChanged();

        try
        {
            var result = await ImapDiscovery.DiscoverAsync(_imapUsername);

            if (result is not null)
            {
                _imapHost = result.Host;
                _imapPort = result.Port;
                _imapEncryption = result.Encryption;

                var message = result.ProviderName is not null
                    ? $"Detected {result.ProviderName}: {result.Host}:{result.Port} ({result.Encryption})"
                    : $"Detected: {result.Host}:{result.Port} ({result.Encryption})";
                Snackbar.Add(message, Severity.Success);
            }
            else
            {
                Snackbar.Add("Could not auto-detect IMAP settings. Please enter them manually.", Severity.Warning);
                _showAdvancedImap = true;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Auto-detection failed: {ex.Message}", Severity.Error);
            _showAdvancedImap = true;
        }
        finally
        {
            _isAutoDetecting = false;
            StateHasChanged();
        }
    }

    private async Task TestImapConnection()
    {
        if (string.IsNullOrWhiteSpace(_imapHost))
        {
            Snackbar.Add("Please enter an IMAP host first.", Severity.Warning);
            return;
        }

        _isTestingImap = true;
        StateHasChanged();

        try
        {
            ConnectionTestResult result;

            if (_imapAuthType == ImapAuthType.OAuth2)
            {
                if (ExistingJob?.Id is null || !_hasOAuthTokens)
                {
                    Snackbar.Add("Please authorize with Google first.", Severity.Warning);
                    return;
                }

                var freshJob = await JobRepository.GetByIdAsync(ExistingJob.Id);
                if (freshJob?.ImapSettings is null || string.IsNullOrEmpty(freshJob.ImapSettings.EncryptedOAuthRefreshToken))
                {
                    Snackbar.Add("Please authorize with Google first.", Severity.Warning);
                    return;
                }

                var accessToken = await OAuthCredentialProvider.GetAccessTokenAsync(freshJob.ImapSettings);
                result = await ImapTester.TestAsync(_imapHost, _imapPort, _imapEncryption,
                    ImapAuthType.OAuth2, _imapUsername, null, accessToken);
            }
            else
            {
                var password = _imapPassword;
                if (string.IsNullOrEmpty(password) && _hasExistingImapPassword && ExistingJob?.ImapSettings?.EncryptedPassword is not null)
                {
                    password = CredentialEncryptor.Decrypt(ExistingJob.ImapSettings.EncryptedPassword);
                }

                result = await ImapTester.TestAsync(_imapHost, _imapPort, _imapEncryption, _imapUsername, password);
            }

            if (result.Success)
                Snackbar.Add("IMAP connection successful!", Severity.Success);
            else
                Snackbar.Add($"IMAP connection failed: {result.ErrorMessage}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error testing connection: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isTestingImap = false;
            StateHasChanged();
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_sourceEmail) || string.IsNullOrWhiteSpace(_destinationEmail))
        {
            Snackbar.Add("Source and destination email are required.", Severity.Warning);
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            MigrationJob job;

            if (IsEditMode)
            {
                job = ExistingJob!;
                job.SourceEmail = _sourceEmail.Trim();
                job.DestinationEmail = _destinationEmail.Trim();
                job.HasImapOverride = _hasImapOverride;

                // Migration options
                job.MigrationMode = _migrationMode;
                job.DateFrom = _dateFrom.HasValue ? DateTime.SpecifyKind(_dateFrom.Value, DateTimeKind.Utc) : null;
                job.DateTo = _dateTo.HasValue ? DateTime.SpecifyKind(_dateTo.Value, DateTimeKind.Utc) : null;
                job.SkipDuplicates = _migrationMode == MigrationMode.Incremental ? true : _skipDuplicates;
                job.MigrationOptionsConfigured = true;

                // IMAP settings (only when IMAP tab is shown)
                if (_showImapTab && !string.IsNullOrWhiteSpace(_imapHost))
                {
                    job.ImapSettings ??= new ImapSettings();
                    job.ImapSettings.Host = _imapHost;
                    job.ImapSettings.Port = _imapPort;
                    job.ImapSettings.Encryption = _imapEncryption;
                    job.ImapSettings.AuthType = _imapAuthType;
                    job.ImapSettings.Username = _imapUsername;

                    if (_imapAuthType == ImapAuthType.Password)
                    {
                        if (!string.IsNullOrEmpty(_imapPassword))
                            job.ImapSettings.EncryptedPassword = CredentialEncryptor.Encrypt(_imapPassword);

                        job.ImapSettings.OAuthClientId = null;
                        job.ImapSettings.EncryptedOAuthClientSecret = null;
                        job.ImapSettings.EncryptedOAuthAccessToken = null;
                        job.ImapSettings.EncryptedOAuthRefreshToken = null;
                        job.ImapSettings.OAuthTokenExpiresAtUtc = null;
                        job.ImapSettings.OAuthProvider = null;
                    }
                    else
                    {
                        job.ImapSettings.OAuthClientId = _oauthClientId;
                        job.ImapSettings.OAuthProvider = "Google";
                        if (!string.IsNullOrEmpty(_oauthClientSecret))
                            job.ImapSettings.EncryptedOAuthClientSecret = CredentialEncryptor.Encrypt(_oauthClientSecret);

                        job.ImapSettings.EncryptedPassword = null;
                    }
                }

                await JobRepository.UpdateAsync(job);
                Snackbar.Add("Migration job updated.", Severity.Success);
            }
            else
            {
                job = new MigrationJob
                {
                    ProjectId = ProjectId,
                    SourceEmail = _sourceEmail.Trim(),
                    DestinationEmail = _destinationEmail.Trim(),
                    HasImapOverride = _hasImapOverride,
                    MigrationMode = _migrationMode,
                    DateFrom = _dateFrom.HasValue ? DateTime.SpecifyKind(_dateFrom.Value, DateTimeKind.Utc) : null,
                    DateTo = _dateTo.HasValue ? DateTime.SpecifyKind(_dateTo.Value, DateTimeKind.Utc) : null,
                    SkipDuplicates = _migrationMode == MigrationMode.Incremental ? true : _skipDuplicates,
                    MigrationOptionsConfigured = true
                };

                // IMAP settings (only when IMAP tab is shown)
                if (_showImapTab && !string.IsNullOrWhiteSpace(_imapHost))
                {
                    job.ImapSettings = new ImapSettings
                    {
                        Host = _imapHost,
                        Port = _imapPort,
                        Encryption = _imapEncryption,
                        AuthType = _imapAuthType,
                        Username = _imapUsername
                    };

                    if (_imapAuthType == ImapAuthType.Password)
                    {
                        job.ImapSettings.EncryptedPassword = !string.IsNullOrEmpty(_imapPassword)
                            ? CredentialEncryptor.Encrypt(_imapPassword) : null;
                    }
                    else
                    {
                        job.ImapSettings.OAuthClientId = _oauthClientId;
                        job.ImapSettings.OAuthProvider = "Google";
                        job.ImapSettings.EncryptedOAuthClientSecret = !string.IsNullOrEmpty(_oauthClientSecret)
                            ? CredentialEncryptor.Encrypt(_oauthClientSecret) : null;
                    }
                }

                await JobRepository.CreateAsync(job);
                Snackbar.Add("Migration job created.", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(job));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving job: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void Cancel() => MudDialog.Cancel();

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("migrifyOAuth.unregisterCallback");
        }
        catch
        {
            // JS interop may fail if circuit is already disconnected
        }

        _dotNetRef?.Dispose();
    }
}
