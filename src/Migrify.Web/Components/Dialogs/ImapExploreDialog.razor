@inject IImapMailboxExplorer ImapExplorer
@inject ICredentialEncryptor CredentialEncryptor
@inject IImapOAuthCredentialProvider OAuthCredentialProvider
@inject IMigrationJobRepository JobRepository
@inject ICalDavDiscoveryService CalDavDiscovery
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Explore Mailbox — @Job.SourceEmail</MudText>
    </TitleContent>
    <DialogContent>
        @if (_result is not null && _result.Success)
        {
            <MudGrid Class="mb-4">
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Server Address</MudText>
                    <MudText Typo="Typo.body2">@_result.ServerAddress</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Resolved IP</MudText>
                    <MudText Typo="Typo.body2">@(_result.ResolvedIpAddress ?? "Unknown")</MudText>
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.subtitle2" Class="mb-2">
                @_result.Folders.Count folder(s) — @_result.Folders.Sum(f => f.MessageCount).ToString("N0") total messages
            </MudText>

            <MudTable Items="_result.Folders" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Folder</MudTh>
                    <MudTh Style="text-align: right;">Messages</MudTh>
                    <MudTh>First Message</MudTh>
                    <MudTh>Last Message</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Folder">
                        <MudText Typo="Typo.body2">@context.FullName</MudText>
                    </MudTd>
                    <MudTd DataLabel="Messages" Style="text-align: right;">
                        <MudText Typo="Typo.body2">@context.MessageCount.ToString("N0")</MudText>
                    </MudTd>
                    <MudTd DataLabel="First Message">
                        <MudText Typo="Typo.body2">@(context.FirstMessageDate?.ToString("dd-MM-yyyy") ?? "—")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Last Message">
                        <MudText Typo="Typo.body2">@(context.LastMessageDate?.ToString("dd-MM-yyyy") ?? "—")</MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            @* CalDAV discovery result *@
            @if (_calDavStatus is not null)
            {
                <MudDivider Class="my-3" />
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle2">CalDAV:</MudText>
                    @if (_calDavStatus == CalDavSupportStatus.Supported)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Supported</MudChip>
                        @if (!string.IsNullOrEmpty(_calDavProviderName))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">(@_calDavProviderName)</MudText>
                        }
                    }
                    else if (_calDavStatus == CalDavSupportStatus.NotSupported)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Not detected</MudChip>
                    }
                    else if (_calDavStatus == CalDavSupportStatus.NotApplicable)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">N/A — Google Workspace</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Unknown</MudText>
                    }
                </div>
            }
        }
        else if (_result is not null && !_result.Success)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">
                @_result.ErrorMessage
            </MudAlert>
        }
        else if (_isExploring)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Connecting to @Job.ImapSettings!.Host and exploring folders...
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Click "Explore" to connect to the IMAP server and retrieve folder information.
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.FolderOpen"
                   OnClick="Explore" Disabled="_isExploring">
            @if (_isExploring)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Exploring...</span>
            }
            else
            {
                <span>Explore</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public MigrationJob Job { get; set; } = null!;

    [Parameter]
    public SourceConnectorType SourceConnectorType { get; set; }

    private ImapExploreResult? _result;
    private bool _isExploring;
    private CalDavSupportStatus? _calDavStatus;
    private string? _calDavProviderName;

    private async Task Explore()
    {
        var imap = Job.ImapSettings;
        if (imap is null || string.IsNullOrWhiteSpace(imap.Host))
        {
            Snackbar.Add("IMAP settings are not configured for this job.", Severity.Warning);
            return;
        }

        if (imap.AuthType == ImapAuthType.Password && string.IsNullOrEmpty(imap.EncryptedPassword))
        {
            Snackbar.Add("No IMAP password configured. Edit the job to set one.", Severity.Warning);
            return;
        }

        if (imap.AuthType == ImapAuthType.OAuth2 && string.IsNullOrEmpty(imap.EncryptedOAuthRefreshToken))
        {
            Snackbar.Add("No OAuth2 tokens found. Edit the job and authorize with Google first.", Severity.Warning);
            return;
        }

        _isExploring = true;
        _result = null;
        StateHasChanged();

        try
        {
            if (imap.AuthType == ImapAuthType.OAuth2)
            {
                var accessToken = await OAuthCredentialProvider.GetAccessTokenAsync(imap);
                _result = await ImapExplorer.ExploreAsync(
                    imap.Host, imap.Port, imap.Encryption,
                    ImapAuthType.OAuth2, imap.Username ?? string.Empty, null, accessToken);
            }
            else
            {
                var password = CredentialEncryptor.Decrypt(imap.EncryptedPassword!);
                _result = await ImapExplorer.ExploreAsync(
                    imap.Host, imap.Port, imap.Encryption,
                    imap.Username ?? string.Empty, password);
            }

            if (_result.Success)
            {
                imap.LastTestedServerAddress = _result.ServerAddress;
                imap.ResolvedIpAddress = _result.ResolvedIpAddress;

                // CalDAV discovery (non-blocking — errors don't affect IMAP explore)
                await RunCalDavDiscoveryAsync();

                await JobRepository.UpdateAsync(Job);

                Snackbar.Add($"Found {_result.Folders.Count} folder(s) with {_result.Folders.Sum(f => f.MessageCount):N0} messages.", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Explore failed: {_result.ErrorMessage}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExploring = false;
            StateHasChanged();
        }
    }

    private async Task RunCalDavDiscoveryAsync()
    {
        try
        {
            if (SourceConnectorType == SourceConnectorType.GoogleWorkspace)
            {
                Job.CalDavSupportStatus = CalDavSupportStatus.NotApplicable;
                Job.CalDavBaseUrl = null;
                _calDavStatus = CalDavSupportStatus.NotApplicable;
                return;
            }

            var caldavResult = await CalDavDiscovery.DiscoverAsync(Job.SourceEmail);
            Job.CalDavSupportStatus = caldavResult.Status;
            Job.CalDavBaseUrl = caldavResult.BaseUrl;
            _calDavStatus = caldavResult.Status;
            _calDavProviderName = caldavResult.ProviderName;
        }
        catch
        {
            // CalDAV discovery failure should never break IMAP explore
            Job.CalDavSupportStatus = CalDavSupportStatus.Unknown;
            _calDavStatus = CalDavSupportStatus.Unknown;
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
