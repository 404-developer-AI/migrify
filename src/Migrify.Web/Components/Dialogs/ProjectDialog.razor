@inject IProjectRepository ProjectRepository
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEditMode ? "Edit Project" : "New Project")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Project Name" Required="true"
                      RequiredError="Project name is required" Class="mb-3" />
        <MudTextField @bind-Value="_description" Label="Description" Lines="3" Class="mb-3" />
        <MudSelect @bind-Value="_status" Label="Status" Class="mb-3">
            @foreach (var status in Enum.GetValues<ProjectStatus>())
            {
                <MudSelectItem Value="@status">@status</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="_isSaving">
            @(IsEditMode ? "Update" : "Create")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public Project? ExistingProject { get; set; }

    private bool IsEditMode => ExistingProject is not null;

    private string _name = string.Empty;
    private string? _description;
    private ProjectStatus _status = ProjectStatus.New;
    private bool _isSaving;

    protected override void OnParametersSet()
    {
        if (ExistingProject is not null)
        {
            _name = ExistingProject.Name;
            _description = ExistingProject.Description;
            _status = ExistingProject.Status;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            Snackbar.Add("Project name is required.", Severity.Warning);
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            Project project;

            if (IsEditMode)
            {
                project = ExistingProject!;
                project.Name = _name;
                project.Description = _description;
                project.Status = _status;
                await ProjectRepository.UpdateAsync(project);
                Snackbar.Add("Project updated successfully.", Severity.Success);
            }
            else
            {
                project = new Project
                {
                    Name = _name,
                    Description = _description,
                    Status = _status
                };
                await ProjectRepository.CreateAsync(project);
                Snackbar.Add("Project created successfully.", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(project));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving project: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
