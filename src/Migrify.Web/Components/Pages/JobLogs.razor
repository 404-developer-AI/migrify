@page "/projects/{ProjectId:guid}/jobs/{JobId:guid}/logs"
@attribute [Authorize]
@inject IMigrationLogRepository LogRepository
@inject IMigrationJobRepository JobRepository
@inject IProjectRepository ProjectRepository
@inject IMigrationRetryService RetryService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@implements IAsyncDisposable

<PageTitle>Migration Logs - Migrify</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_job is null)
{
    <MudAlert Severity="Severity.Error">Job not found.</MudAlert>
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    <MudCard Class="mb-4" Elevation="0">
        <MudCardContent>
            <MudText Typo="Typo.h5">Migration Logs</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @_job.SourceEmail → @_job.DestinationEmail
            </MudText>
        </MudCardContent>
    </MudCard>

    @* Filter chips *@
    <div class="d-flex align-center gap-2 mb-3 flex-wrap">
        <MudChip T="string" Color="@(_typeFilter is null ? Color.Primary : Color.Default)"
                 OnClick="() => SetTypeFilter(null)" Size="Size.Small">
            All (@_totalAll)
        </MudChip>
        <MudChip T="string" Color="@(_typeFilter == MigrationLogType.Error ? Color.Error : Color.Default)"
                 OnClick="() => SetTypeFilter(MigrationLogType.Error)" Size="Size.Small">
            Errors (@_countError)
        </MudChip>
        <MudChip T="string" Color="@(_typeFilter == MigrationLogType.Skipped ? Color.Warning : Color.Default)"
                 OnClick="() => SetTypeFilter(MigrationLogType.Skipped)" Size="Size.Small">
            Skipped (@_countSkipped)
        </MudChip>
        <MudChip T="string" Color="@(_typeFilter == MigrationLogType.Summary ? Color.Info : Color.Default)"
                 OnClick="() => SetTypeFilter(MigrationLogType.Summary)" Size="Size.Small">
            Summary (@_countSummary)
        </MudChip>
        <MudChip T="string" Color="@(_typeFilter == MigrationLogType.Retried ? Color.Success : Color.Default)"
                 OnClick="() => SetTypeFilter(MigrationLogType.Retried)" Size="Size.Small">
            Retried (@_countRetried)
        </MudChip>

        <MudSpacer />

        @if (_countError > 0)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Replay"
                       OnClick="RetryAllFailed" Disabled="_isRetryingAll">
                @if (_isRetryingAll)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                    <span>Retrying...</span>
                }
                else
                {
                    <span>Retry all failed (@_countError)</span>
                }
            </MudButton>
        }

        <MudTextField T="string" @bind-Value="_searchText" Placeholder="Search subject or error..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="300" TextChanged="OnSearchChanged"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 300px;" />
    </div>

    @* Log table *@
    <MudTable @ref="_table" ServerData="LoadLogs" Dense="true" Hover="true" Elevation="0"
              RowsPerPage="25" T="MigrationLog">
        <HeaderContent>
            <MudTh>Type</MudTh>
            <MudTh>Subject</MudTh>
            <MudTh>Date</MudTh>
            <MudTh>Source Folder</MudTh>
            <MudTh>Details</MudTh>
            <MudTh Style="width: 80px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            @if (context.Type == MigrationLogType.Summary)
            {
                <MudTd DataLabel="Type">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">Summary</MudChip>
                </MudTd>
                <MudTd DataLabel="Subject" colspan="5">
                    <MudText Typo="Typo.body2">
                        @context.TotalProcessed processed, @context.TotalFailed failed,
                        @context.TotalSkipped skipped, @context.TotalDuplicates duplicates
                    </MudText>
                </MudTd>
            }
            else
            {
                <MudTd DataLabel="Type">
                    @if (context.Type == MigrationLogType.Retried)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Retried</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.Type == MigrationLogType.Error ? Color.Error : Color.Warning)">
                            @context.Type
                        </MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="Subject">
                    <MudText Typo="Typo.body2" Style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        @(context.Subject ?? "—")
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Date">
                    @(context.MessageDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                </MudTd>
                <MudTd DataLabel="Source Folder">@(context.SourceFolder ?? "—")</MudTd>
                <MudTd DataLabel="Details">
                    @if (!string.IsNullOrEmpty(context.ErrorMessage))
                    {
                        <MudTooltip Text="@context.ErrorMessage">
                            <MudText Typo="Typo.body2" Style="max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @context.ErrorMessage
                            </MudText>
                        </MudTooltip>
                    }
                </MudTd>
                <MudTd DataLabel="Actions">
                    @if (context.Type == MigrationLogType.Error)
                    {
                        @if (context.SourceUid is not null && !string.IsNullOrEmpty(context.DestinationFolderId))
                        {
                            <MudTooltip Text="Retry this message">
                                <MudIconButton Icon="@Icons.Material.Filled.Replay" Size="Size.Small"
                                               Color="Color.Primary"
                                               Disabled="@(_retryingLogIds.Contains(context.Id))"
                                               OnClick="@(() => RetryMessage(context))" />
                            </MudTooltip>
                        }
                        else
                        {
                            <MudTooltip Text="Retry not available (pre-v0.0.12 log)">
                                <MudIcon Icon="@Icons.Material.Filled.Replay" Size="Size.Small" Color="Color.Default" />
                            </MudTooltip>
                        }
                    }
                    else if (context.Type == MigrationLogType.Retried)
                    {
                        <MudTooltip Text="Successfully retried">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                        </MudTooltip>
                    }
                </MudTd>
            }
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
        </PagerContent>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Color="Color.Secondary">No log entries found.</MudText>
        </NoRecordsContent>
    </MudTable>
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public Guid JobId { get; set; }

    private MigrationJob? _job;
    private Project? _project;
    private bool _loading = true;
    private MigrationLogType? _typeFilter;
    private string? _searchText;
    private MudTable<MigrationLog>? _table;
    private HubConnection? _hubConnection;

    private int _countError;
    private int _countSkipped;
    private int _countSummary;
    private int _countRetried;
    private int _totalAll;

    private HashSet<Guid> _retryingLogIds = new();
    private bool _isRetryingAll;

    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        _project = await ProjectRepository.GetByIdAsync(ProjectId);
        _job = await JobRepository.GetByIdAsync(JobId);
        _loading = false;

        if (_project is not null && _job is not null)
        {
            _breadcrumbs = new List<BreadcrumbItem>
            {
                new("Projects", "/projects"),
                new(_project.Name, $"/projects/{ProjectId}"),
                new(_job.SourceEmail, $"/projects/{ProjectId}"),
                new("Logs", null, disabled: true)
            };

            await LoadCounts();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _project is not null && _job is not null)
        {
            await SetupSignalR();
        }
    }

    private async Task LoadCounts()
    {
        var counts = await LogRepository.GetCountsByJobIdAsync(JobId);
        _countError = counts.GetValueOrDefault(MigrationLogType.Error);
        _countSkipped = counts.GetValueOrDefault(MigrationLogType.Skipped);
        _countSummary = counts.GetValueOrDefault(MigrationLogType.Summary);
        _countRetried = counts.GetValueOrDefault(MigrationLogType.Retried);
        _totalAll = _countError + _countSkipped + _countSummary + _countRetried;
    }

    private async Task<TableData<MigrationLog>> LoadLogs(TableState state, CancellationToken ct)
    {
        var (items, totalCount) = await LogRepository.GetByJobIdAsync(
            JobId, state.Page, state.PageSize, _typeFilter, _searchText);
        return new TableData<MigrationLog> { Items = items, TotalItems = totalCount };
    }

    private async Task SetTypeFilter(MigrationLogType? type)
    {
        _typeFilter = type;
        if (_table is not null)
            await _table.ReloadServerData();
    }

    private async Task OnSearchChanged(string? text)
    {
        _searchText = text;
        if (_table is not null)
            await _table.ReloadServerData();
    }

    private async Task RetryMessage(MigrationLog log)
    {
        _retryingLogIds.Add(log.Id);
        StateHasChanged();

        try
        {
            var success = await RetryService.RetryAsync(log.Id);
            if (success)
                Snackbar.Add($"Successfully retried: {log.Subject ?? "message"}", Severity.Success);
            else
                Snackbar.Add($"Retry failed for: {log.Subject ?? "message"}", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Retry error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _retryingLogIds.Remove(log.Id);
            await LoadCounts();
            if (_table is not null)
                await _table.ReloadServerData();
            StateHasChanged();
        }
    }

    private async Task RetryAllFailed()
    {
        _isRetryingAll = true;
        StateHasChanged();

        try
        {
            var (succeeded, failed) = await RetryService.RetryAllFailedAsync(JobId);
            Snackbar.Add($"Retry complete: {succeeded} succeeded, {failed} failed",
                succeeded > 0 && failed == 0 ? Severity.Success : Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Retry error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isRetryingAll = false;
            await LoadCounts();
            if (_table is not null)
                await _table.ReloadServerData();
            StateHasChanged();
        }
    }

    private async Task SetupSignalR()
    {
        try
        {
            var hubUrl = Configuration.GetValue<bool>("ReverseProxy:Enabled")
                ? new Uri("http://localhost:8080/hubs/migration-progress")
                : NavigationManager.ToAbsoluteUri("/hubs/migration-progress");

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(hubUrl)
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<Guid, string, string?, string?, string?>("ReceiveLogEntry",
                async (jobId, type, subject, sourceFolder, errorMessage) =>
                {
                    if (jobId != JobId) return;
                    await InvokeAsync(async () =>
                    {
                        await LoadCounts();
                        if (_table is not null)
                            await _table.ReloadServerData();
                        StateHasChanged();
                    });
                });

            _hubConnection.On<Guid, int, int, int, int, string?>("ReceiveJobCompleted",
                async (jobId, processed, total, failed, skipped, errorMessage) =>
                {
                    if (jobId != JobId) return;
                    await InvokeAsync(async () =>
                    {
                        await LoadCounts();
                        if (_table is not null)
                            await _table.ReloadServerData();
                        StateHasChanged();
                    });
                });

            _hubConnection.On<Guid, Guid, bool>("ReceiveRetryResult",
                async (jobId, logId, success) =>
                {
                    if (jobId != JobId) return;
                    await InvokeAsync(async () =>
                    {
                        await LoadCounts();
                        if (_table is not null)
                            await _table.ReloadServerData();
                        StateHasChanged();
                    });
                });

            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinProject", ProjectId);
        }
        catch (Exception)
        {
            // Hub connection failure should not crash the circuit
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.DisposeAsync();
            }
            catch { /* ignore disposal errors */ }
        }
    }
}
