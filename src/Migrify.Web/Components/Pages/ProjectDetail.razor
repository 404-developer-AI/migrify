@page "/projects/{ProjectId:guid}"
@attribute [Authorize]
@inject IProjectRepository ProjectRepository
@inject IMigrationJobRepository JobRepository
@inject IDiscoveredMailboxRepository DiscoveredMailboxRepository
@inject ICredentialEncryptor CredentialEncryptor
@inject IM365MailboxDiscovery M365Discovery
@inject IGoogleWorkspaceMailboxDiscovery GoogleDiscovery
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>@(_project?.Name ?? "Project") - Migrify</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_project is null)
{
    <MudAlert Severity="Severity.Error">Project not found.</MudAlert>
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @* Project Info Card *@
    <MudCard Class="mb-4" Elevation="0">
        <MudCardContent>
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.h5">@_project.Name</MudText>
                    @if (!string.IsNullOrEmpty(_project.Description))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_project.Description</MudText>
                    }
                </div>
                <div class="d-flex align-center gap-2">
                    <MudChip T="string" Size="Size.Small" Color="@GetProjectStatusColor(_project.Status)">
                        @_project.Status
                    </MudChip>
                    <MudTooltip Text="Edit Project">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="OpenEditProjectDialog" />
                    </MudTooltip>
                </div>
            </div>
        </MudCardContent>
    </MudCard>

    @* Connectors *@
    <MudText Typo="Typo.h6" Class="section-title mb-3">Connectors</MudText>
    <MudGrid Class="mb-4">
        @* Source Connector *@
        <MudItem xs="12" md="6">
            <MudCard Elevation="0" Style="height: 100%;">
                <MudCardContent>
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.subtitle1"><strong>Source</strong></MudText>
                        <MudChip T="string" Size="Size.Small" Color="@(_project.SourceConnectorType == SourceConnectorType.GoogleWorkspace ? Color.Primary : Color.Default)">
                            @(_project.SourceConnectorType == SourceConnectorType.GoogleWorkspace ? "Google Workspace" : "Manual IMAP")
                        </MudChip>
                    </div>
                    @if (_project.SourceConnectorType == SourceConnectorType.ManualImap)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Each job manages its own IMAP credentials.
                        </MudText>
                    }
                    else if (_project.GoogleWorkspaceSettings is not null)
                    {
                        <MudText Typo="Typo.body2">Domain: <strong>@_project.GoogleWorkspaceSettings.Domain</strong></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_project.GoogleWorkspaceSettings.ServiceAccountEmail</MudText>
                        @if (_sourceMailboxCount > 0)
                        {
                            <MudText Typo="Typo.body2" Class="mt-1">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                @_sourceMailboxCount mailbox(es) discovered
                            </MudText>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Warning">Not configured yet.</MudText>
                    }
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Settings"
                               OnClick="OpenSourceConnectorDialog">
                        Configure
                    </MudButton>
                    @if (_project.SourceConnectorType == SourceConnectorType.GoogleWorkspace && _project.GoogleWorkspaceSettings is not null)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   OnClick="DiscoverSourceMailboxes" Disabled="_isDiscoveringSource">
                            @if (_isDiscoveringSource)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                <span>Discovering...</span>
                            }
                            else
                            {
                                <span>Discover Mailboxes</span>
                            }
                        </MudButton>
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>

        @* Destination Connector *@
        <MudItem xs="12" md="6">
            <MudCard Elevation="0" Style="height: 100%;">
                <MudCardContent>
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.subtitle1"><strong>Destination</strong></MudText>
                        <MudChip T="string" Size="Size.Small" Color="@(_project.M365Settings is not null ? Color.Primary : Color.Default)">
                            Microsoft 365
                        </MudChip>
                    </div>
                    @if (_project.M365Settings is not null && !string.IsNullOrEmpty(_project.M365Settings.TenantId))
                    {
                        <MudText Typo="Typo.body2">Tenant: <strong>@_project.M365Settings.TenantId[..Math.Min(8, _project.M365Settings.TenantId.Length)]...</strong></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Client: @_project.M365Settings.ClientId</MudText>
                        @if (_destMailboxCount > 0)
                        {
                            <MudText Typo="Typo.body2" Class="mt-1">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                @_destMailboxCount mailbox(es) discovered
                            </MudText>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Warning">Not configured yet.</MudText>
                    }
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Settings"
                               OnClick="OpenDestinationConnectorDialog">
                        Configure
                    </MudButton>
                    @if (_project.M365Settings is not null && !string.IsNullOrEmpty(_project.M365Settings.TenantId))
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   OnClick="DiscoverDestinationMailboxes" Disabled="_isDiscoveringDest">
                            @if (_isDiscoveringDest)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                <span>Discovering...</span>
                            }
                            else
                            {
                                <span>Discover Mailboxes</span>
                            }
                        </MudButton>
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* Migration Jobs *@
    <div class="d-flex justify-space-between align-center mb-3">
        <MudText Typo="Typo.h6" Class="section-title">Migration Jobs</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                   OnClick="OpenAddJobDialog">
            Add Job
        </MudButton>
    </div>

    @if (_jobs.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            No migration jobs yet. Click "Add Job" to create your first job.
        </MudAlert>
    }
    else
    {
        <MudTable Items="_jobs" Hover="true" Elevation="0">
            <HeaderContent>
                <MudTh>Source Email</MudTh>
                <MudTh>Destination Email</MudTh>
                <MudTh>Source Auth</MudTh>
                <MudTh>Mapping</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Created</MudTh>
                <MudTh Style="width: 220px;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Source Email">
                    <MudText Typo="Typo.body2">@context.SourceEmail</MudText>
                </MudTd>
                <MudTd DataLabel="Destination Email">
                    <MudText Typo="Typo.body2">
                        @(string.IsNullOrEmpty(context.DestinationEmail) ? "\u2014" : context.DestinationEmail)
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Source Auth">
                    @if (context.HasImapOverride && context.ImapSettings is not null && !string.IsNullOrEmpty(context.ImapSettings.Host))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                            IMAP Override
                        </MudChip>
                    }
                    else if (_project.SourceConnectorType == SourceConnectorType.GoogleWorkspace && !context.HasImapOverride)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            Google Workspace
                        </MudChip>
                    }
                    else if (context.ImapSettings is not null && !string.IsNullOrEmpty(context.ImapSettings.Host))
                    {
                        <MudText Typo="Typo.body2">@context.ImapSettings.Host:@context.ImapSettings.Port</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Not configured</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Mapping">
                    @if (context.FolderMappings.Any())
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                            @context.FolderMappings.Count mapped
                        </MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Not mapped</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@GetJobStatusColor(context.Status)">
                        @context.Status
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Created">
                    <MudText Typo="Typo.body2">@context.CreatedAt.ToString("dd-MM-yyyy HH:mm")</MudText>
                </MudTd>
                <MudTd>
                    @if (context.ImapSettings is not null && !string.IsNullOrEmpty(context.ImapSettings.Host))
                    {
                        <MudTooltip Text="Explore IMAP Mailbox">
                            <MudIconButton Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenExploreDialog(context))" />
                        </MudTooltip>
                    }
                    @if (_project.M365Settings is not null && !string.IsNullOrEmpty(_project.M365Settings.TenantId))
                    {
                        <MudTooltip Text="Explore M365 Mailbox">
                            <MudIconButton Icon="@Icons.Material.Filled.CloudQueue" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenM365ExploreDialog(context))" />
                        </MudTooltip>
                    }
                    @if (HasSourceAccess(context) && _project.M365Settings is not null && !string.IsNullOrEmpty(_project.M365Settings.TenantId))
                    {
                        <MudTooltip Text="Map Folders">
                            <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenFolderMappingDialog(context))" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => OpenEditJobDialog(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => OpenDeleteJobDialog(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    private Project? _project;
    private List<MigrationJob> _jobs = new();
    private bool _loading = true;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private int _sourceMailboxCount;
    private int _destMailboxCount;
    private bool _isDiscoveringSource;
    private bool _isDiscoveringDest;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _project = await ProjectRepository.GetByIdWithConnectorsAsync(ProjectId);

        if (_project is null)
        {
            _loading = false;
            return;
        }

        _jobs = await JobRepository.GetByProjectIdAsync(ProjectId);
        _sourceMailboxCount = _project.DiscoveredMailboxes.Count(m => m.Side == MailboxSide.Source);
        _destMailboxCount = _project.DiscoveredMailboxes.Count(m => m.Side == MailboxSide.Destination);
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Projects", href: "/projects"),
            new(_project.Name, href: null, disabled: true)
        };
        _loading = false;
    }

    private async Task OpenSourceConnectorDialog()
    {
        var parameters = new DialogParameters
        {
            { nameof(SourceConnectorDialog.Project), _project }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SourceConnectorDialog>("Configure Source", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadData();
    }

    private async Task OpenDestinationConnectorDialog()
    {
        var parameters = new DialogParameters
        {
            { nameof(DestinationConnectorDialog.Project), _project }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<DestinationConnectorDialog>("Configure Destination", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadData();
    }

    private async Task DiscoverSourceMailboxes()
    {
        if (_project?.GoogleWorkspaceSettings is null) return;

        _isDiscoveringSource = true;
        StateHasChanged();

        try
        {
            var gws = _project.GoogleWorkspaceSettings;
            var privateKey = CredentialEncryptor.Decrypt(gws.EncryptedPrivateKey!);

            var discovered = await GoogleDiscovery.DiscoverMailboxesAsync(
                gws.ServiceAccountEmail, privateKey, gws.TokenUri, gws.ImpersonationEmail, gws.Domain);

            var mailboxes = discovered.Select(d => new DiscoveredMailbox
            {
                Email = d.Email,
                DisplayName = d.DisplayName
            }).ToList();

            await DiscoveredMailboxRepository.ReplaceAllAsync(ProjectId, MailboxSide.Source, mailboxes);
            Snackbar.Add($"Discovered {discovered.Count} source mailboxes.", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Discovery failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isDiscoveringSource = false;
            StateHasChanged();
        }
    }

    private async Task DiscoverDestinationMailboxes()
    {
        if (_project?.M365Settings is null) return;

        _isDiscoveringDest = true;
        StateHasChanged();

        try
        {
            var m365 = _project.M365Settings;
            var secret = CredentialEncryptor.Decrypt(m365.EncryptedClientSecret!);

            var discovered = await M365Discovery.DiscoverMailboxesAsync(m365.TenantId!, m365.ClientId!, secret);

            var mailboxes = discovered.Select(d => new DiscoveredMailbox
            {
                Email = d.Email,
                DisplayName = d.DisplayName
            }).ToList();

            await DiscoveredMailboxRepository.ReplaceAllAsync(ProjectId, MailboxSide.Destination, mailboxes);
            Snackbar.Add($"Discovered {discovered.Count} destination mailboxes.", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Discovery failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isDiscoveringDest = false;
            StateHasChanged();
        }
    }

    private async Task OpenEditProjectDialog()
    {
        var parameters = new DialogParameters
        {
            { nameof(ProjectDialog.ExistingProject), _project }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ProjectDialog>("Edit Project", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadData();
    }

    private async Task OpenExploreDialog(MigrationJob job)
    {
        var parameters = new DialogParameters
        {
            { nameof(ImapExploreDialog.Job), job }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<ImapExploreDialog>("Explore Mailbox", parameters, options);
    }

    private async Task OpenM365ExploreDialog(MigrationJob job)
    {
        var parameters = new DialogParameters
        {
            { nameof(M365ExploreDialog.M365Settings), _project?.M365Settings },
            { nameof(M365ExploreDialog.DestinationEmail), job.DestinationEmail }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<M365ExploreDialog>("Explore M365 Mailbox", parameters, options);
    }

    private async Task OpenFolderMappingDialog(MigrationJob job)
    {
        var parameters = new DialogParameters
        {
            { nameof(FolderMappingDialog.Job), job },
            { nameof(FolderMappingDialog.Project), _project }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FolderMappingDialog>("Folder Mapping", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadData();
    }

    private bool HasSourceAccess(MigrationJob job)
    {
        if (job.HasImapOverride || _project!.SourceConnectorType == SourceConnectorType.ManualImap)
            return job.ImapSettings is not null && !string.IsNullOrEmpty(job.ImapSettings.Host);
        if (_project.SourceConnectorType == SourceConnectorType.GoogleWorkspace)
            return _project.GoogleWorkspaceSettings is not null && !string.IsNullOrEmpty(_project.GoogleWorkspaceSettings.EncryptedPrivateKey);
        return false;
    }

    private async Task OpenAddJobDialog()
    {
        var parameters = new DialogParameters
        {
            { nameof(MigrationJobDialog.ProjectId), ProjectId },
            { nameof(MigrationJobDialog.ProjectSourceConnectorType), _project!.SourceConnectorType },
            { nameof(MigrationJobDialog.SourceMailboxes), _project.DiscoveredMailboxes.Where(m => m.Side == MailboxSide.Source).ToList() },
            { nameof(MigrationJobDialog.DestinationMailboxes), _project.DiscoveredMailboxes.Where(m => m.Side == MailboxSide.Destination).ToList() }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<MigrationJobDialog>("New Migration Job", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadData();
    }

    private async Task OpenEditJobDialog(MigrationJob job)
    {
        var parameters = new DialogParameters
        {
            { nameof(MigrationJobDialog.ProjectId), ProjectId },
            { nameof(MigrationJobDialog.ExistingJob), job },
            { nameof(MigrationJobDialog.ProjectSourceConnectorType), _project!.SourceConnectorType },
            { nameof(MigrationJobDialog.SourceMailboxes), _project.DiscoveredMailboxes.Where(m => m.Side == MailboxSide.Source).ToList() },
            { nameof(MigrationJobDialog.DestinationMailboxes), _project.DiscoveredMailboxes.Where(m => m.Side == MailboxSide.Destination).ToList() }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<MigrationJobDialog>("Edit Migration Job", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadData();
    }

    private async Task OpenDeleteJobDialog(MigrationJob job)
    {
        var parameters = new DialogParameters
        {
            { nameof(DeleteConfirmationDialog.Title), "Delete Migration Job" },
            { nameof(DeleteConfirmationDialog.Message), $"Are you sure you want to delete the migration job for <strong>{job.SourceEmail}</strong>? This will also remove all associated IMAP settings." }
        };

        var dialog = await DialogService.ShowAsync<DeleteConfirmationDialog>("Delete Migration Job", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await JobRepository.DeleteAsync(job.Id);
            Snackbar.Add($"Migration job for '{job.SourceEmail}' deleted.", Severity.Success);
            await LoadData();
        }
    }

    private static Color GetProjectStatusColor(ProjectStatus status) => status switch
    {
        ProjectStatus.New => Color.Info,
        ProjectStatus.Active => Color.Warning,
        ProjectStatus.Completed => Color.Success,
        _ => Color.Default
    };

    private static Color GetJobStatusColor(MigrationJobStatus status) => status switch
    {
        MigrationJobStatus.New => Color.Info,
        MigrationJobStatus.Ready => Color.Default,
        MigrationJobStatus.Running => Color.Warning,
        MigrationJobStatus.Paused => Color.Secondary,
        MigrationJobStatus.Completed => Color.Success,
        MigrationJobStatus.Failed => Color.Error,
        MigrationJobStatus.Cancelled => Color.Dark,
        _ => Color.Default
    };
}
