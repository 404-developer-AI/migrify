@page "/projects/{ProjectId:guid}"
@attribute [Authorize]
@inject IProjectRepository ProjectRepository
@inject IMigrationJobRepository JobRepository
@inject IDiscoveredMailboxRepository DiscoveredMailboxRepository
@inject ICredentialEncryptor CredentialEncryptor
@inject IM365MailboxDiscovery M365Discovery
@inject IGoogleWorkspaceMailboxDiscovery GoogleDiscovery
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@inject IMigrationQueueService MigrationQueue
@inject IConcurrencyLimitService LimitService
@inject Migrify.Infrastructure.Services.SourceLimitProvider SourceLimitProvider
@implements IAsyncDisposable

<PageTitle>@(_project?.Name ?? "Project") - Migrify</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_project is null)
{
    <MudAlert Severity="Severity.Error">Project not found.</MudAlert>
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @* Project Info Card *@
    <MudCard Class="mb-4" Elevation="0">
        <MudCardContent>
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.h5">@_project.Name</MudText>
                    @if (!string.IsNullOrEmpty(_project.Description))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_project.Description</MudText>
                    }
                </div>
                <div class="d-flex align-center gap-2">
                    <MudChip T="string" Size="Size.Small" Color="@GetProjectStatusColor(_project.ComputedStatus)">
                        @_project.ComputedStatus
                    </MudChip>
                    <MudTooltip Text="View All Logs">
                        <MudIconButton Icon="@Icons.Material.Filled.Description" Size="Size.Small"
                                       Color="Color.Info"
                                       Href="@($"/projects/{ProjectId}/logs")" />
                    </MudTooltip>
                    <MudTooltip Text="Edit Project">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="OpenEditProjectDialog" />
                    </MudTooltip>
                </div>
            </div>
        </MudCardContent>
    </MudCard>

    @* Connectors *@
    <MudText Typo="Typo.h6" Class="section-title mb-3">Connectors</MudText>
    <MudGrid Class="mb-4">
        @* Source Connector *@
        <MudItem xs="12" md="6">
            <MudCard Elevation="0" Style="height: 100%;">
                <MudCardContent>
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.subtitle1"><strong>Source</strong></MudText>
                        <MudChip T="string" Size="Size.Small" Color="@(_project.SourceConnectorType == SourceConnectorType.GoogleWorkspace ? Color.Primary : Color.Default)">
                            @(_project.SourceConnectorType == SourceConnectorType.GoogleWorkspace ? "Google Workspace" : "Manual IMAP")
                        </MudChip>
                    </div>
                    @if (_project.SourceConnectorType == SourceConnectorType.ManualImap)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Each job manages its own IMAP credentials.
                        </MudText>
                    }
                    else if (_project.GoogleWorkspaceSettings is not null)
                    {
                        <MudText Typo="Typo.body2">Domain: <strong>@_project.GoogleWorkspaceSettings.Domain</strong></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_project.GoogleWorkspaceSettings.ServiceAccountEmail</MudText>
                        @if (_sourceMailboxCount > 0)
                        {
                            <MudText Typo="Typo.body2" Class="mt-1">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                @_sourceMailboxCount mailbox(es) discovered
                            </MudText>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Warning">Not configured yet.</MudText>
                    }
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Settings"
                               OnClick="OpenSourceConnectorDialog">
                        Configure
                    </MudButton>
                    @if (_project.SourceConnectorType == SourceConnectorType.GoogleWorkspace && _project.GoogleWorkspaceSettings is not null)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   OnClick="DiscoverSourceMailboxes" Disabled="_isDiscoveringSource">
                            @if (_isDiscoveringSource)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                <span>Discovering...</span>
                            }
                            else
                            {
                                <span>Discover Mailboxes</span>
                            }
                        </MudButton>
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>

        @* Destination Connector *@
        <MudItem xs="12" md="6">
            <MudCard Elevation="0" Style="height: 100%;">
                <MudCardContent>
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.subtitle1"><strong>Destination</strong></MudText>
                        <MudChip T="string" Size="Size.Small" Color="@(_project.M365Settings is not null ? Color.Primary : Color.Default)">
                            Microsoft 365
                        </MudChip>
                    </div>
                    @if (_project.M365Settings is not null && !string.IsNullOrEmpty(_project.M365Settings.TenantId))
                    {
                        <MudText Typo="Typo.body2">Tenant: <strong>@_project.M365Settings.TenantId[..Math.Min(8, _project.M365Settings.TenantId.Length)]...</strong></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Client: @_project.M365Settings.ClientId</MudText>
                        @if (_destMailboxCount > 0)
                        {
                            <MudText Typo="Typo.body2" Class="mt-1">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                @_destMailboxCount mailbox(es) discovered
                            </MudText>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Warning">Not configured yet.</MudText>
                    }
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Settings"
                               OnClick="OpenDestinationConnectorDialog">
                        Configure
                    </MudButton>
                    @if (_project.M365Settings is not null && !string.IsNullOrEmpty(_project.M365Settings.TenantId))
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   OnClick="DiscoverDestinationMailboxes" Disabled="_isDiscoveringDest">
                            @if (_isDiscoveringDest)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                <span>Discovering...</span>
                            }
                            else
                            {
                                <span>Discover Mailboxes</span>
                            }
                        </MudButton>
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* Concurrency Limits *@
    <ConcurrencyLimitPanel Overview="@_concurrencyOverview" />

    @* Migration Jobs *@
    <div class="d-flex justify-space-between align-center mb-3">
        <MudText Typo="Typo.h6" Class="section-title">Migration Jobs</MudText>
        <div class="d-flex align-center gap-2">
            @if (_jobs.Count > 0)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           Disabled="@(!_selectedJobs.Any(id => _jobs.Any(j => j.Id == id && CanStartMigration(j))))"
                           OnClick="StartSelectedJobs">
                    Start Selected (@_selectedJobs.Count(id => _jobs.Any(j => j.Id == id && CanStartMigration(j))))
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.PlayCircle"
                           Disabled="@(!_jobs.Any(CanStartMigration))"
                           OnClick="StartAllJobs">
                    Start All
                </MudButton>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                       OnClick="OpenAddJobDialog">
                Add Job
            </MudButton>
        </div>
    </div>

    @if (_jobs.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            No migration jobs yet. Click "Add Job" to create your first job.
        </MudAlert>
    }
    else
    {
        <MudTable Items="_jobs" Hover="true" Elevation="0">
            <HeaderContent>
                <MudTh Style="width: 50px;">
                    <MudCheckBox T="bool" Value="@(_selectedJobs.Count == _jobs.Count(CanStartMigration) && _jobs.Any(CanStartMigration))"
                                 ValueChanged="@(v => ToggleSelectAll(v))"
                                 Size="Size.Small" Color="Color.Primary"
                                 Disabled="@(!_jobs.Any(CanStartMigration))" />
                </MudTh>
                <MudTh>Source Email</MudTh>
                <MudTh>Destination Email</MudTh>
                <MudTh>Source Auth</MudTh>
                <MudTh>Mapping</MudTh>
                <MudTh>Options</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>CalDAV</MudTh>
                <MudTh>Created</MudTh>
                <MudTh Style="width: 220px;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudCheckBox T="bool" Value="@(_selectedJobs.Contains(context.Id))"
                                 ValueChanged="@(v => ToggleJobSelection(context.Id, v))"
                                 Size="Size.Small" Color="Color.Primary"
                                 Disabled="@(!CanStartMigration(context))" />
                </MudTd>
                <MudTd DataLabel="Source Email">
                    <MudText Typo="Typo.body2">@context.SourceEmail</MudText>
                </MudTd>
                <MudTd DataLabel="Destination Email">
                    <MudText Typo="Typo.body2">
                        @(string.IsNullOrEmpty(context.DestinationEmail) ? "\u2014" : context.DestinationEmail)
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Source Auth">
                    @if (context.HasImapOverride && context.ImapSettings is not null && !string.IsNullOrEmpty(context.ImapSettings.Host))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                            IMAP Override
                        </MudChip>
                    }
                    else if (_project.SourceConnectorType == SourceConnectorType.GoogleWorkspace && !context.HasImapOverride)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            Google Workspace
                        </MudChip>
                    }
                    else if (context.ImapSettings is not null && !string.IsNullOrEmpty(context.ImapSettings.Host))
                    {
                        <MudText Typo="Typo.body2">@context.ImapSettings.Host:@context.ImapSettings.Port</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Not configured</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Mapping">
                    @if (context.FolderMappings.Any())
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                            @context.FolderMappings.Count mapped
                        </MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Not mapped</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Options">
                    @if (context.MigrationOptionsConfigured)
                    {
                        <MudTooltip Text="@GetOptionsTooltip(context)">
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(context.MigrationMode == MigrationMode.Incremental ? Color.Info : Color.Success)"
                                     Variant="Variant.Outlined">
                                @(context.MigrationMode == MigrationMode.Incremental ? "Incremental" : "Full Copy")@(context.DateFrom.HasValue || context.DateTo.HasValue ? " *" : "")
                            </MudChip>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudTooltip Text="Migration options must be configured before starting">
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                Not configured
                            </MudChip>
                        </MudTooltip>
                    }
                </MudTd>
                <MudTd DataLabel="Status">
                    @if (context.Status is MigrationJobStatus.Completed or MigrationJobStatus.Failed or MigrationJobStatus.Cancelled
                        && context.StartedAt.HasValue)
                    {
                        <MudTooltip>
                            <TooltipContent>
                                <div style="text-align: left; white-space: pre-line;">
                                    <div>Started: @context.StartedAt.Value.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")</div>
                                    @if (context.CompletedAt.HasValue)
                                    {
                                        <div>Finished: @context.CompletedAt.Value.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")</div>
                                        <div>Duration: @FormatDuration(context.CompletedAt.Value - context.StartedAt.Value)</div>
                                    }
                                    @if (!string.IsNullOrEmpty(context.ErrorMessage))
                                    {
                                        <div class="mt-1">@context.ErrorMessage</div>
                                    }
                                </div>
                            </TooltipContent>
                            <ChildContent>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(context.Status == MigrationJobStatus.Completed && !string.IsNullOrEmpty(context.ErrorMessage)
                                             ? Color.Warning : GetJobStatusColor(context.Status))">
                                    @context.Status
                                </MudChip>
                            </ChildContent>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="@GetJobStatusColor(context.Status)">
                            @context.Status
                        </MudChip>
                    }
                    @if (context.Status == MigrationJobStatus.Running)
                    {
                        <MudProgressLinear Value="@GetProgressPercent(context)" Color="Color.Primary"
                                           Class="mt-1" Rounded="true" Size="Size.Small" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @context.ProcessedMessages / @context.TotalMessages
                            @if (context.DuplicateMessages > 0)
                            {
                                <span> (@context.DuplicateMessages already present)</span>
                            }
                            @if (!string.IsNullOrEmpty(context.CurrentFolder))
                            {
                                <span> — @context.CurrentFolder</span>
                            }
                        </MudText>
                    }
                    @if (context.Status == MigrationJobStatus.Failed && !string.IsNullOrEmpty(context.ErrorMessage))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Error">@context.ErrorMessage</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="CalDAV">
                    @switch (context.CalDavSupportStatus)
                    {
                        case CalDavSupportStatus.Supported:
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                Supported
                            </MudChip>
                            break;
                        case CalDavSupportStatus.NotSupported:
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                Not Supported
                            </MudChip>
                            break;
                        case CalDavSupportStatus.NotApplicable:
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                N/A
                            </MudChip>
                            break;
                        default:
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Unknown</MudText>
                            break;
                    }
                </MudTd>
                <MudTd DataLabel="Created">
                    <MudText Typo="Typo.body2">@context.CreatedAt.ToString("dd-MM-yyyy HH:mm")</MudText>
                </MudTd>
                <MudTd>
                    @if (context.ImapSettings is not null && !string.IsNullOrEmpty(context.ImapSettings.Host))
                    {
                        <MudTooltip Text="Explore IMAP Mailbox">
                            <MudIconButton Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenExploreDialog(context))" />
                        </MudTooltip>
                    }
                    @if (context.CalDavSupportStatus == CalDavSupportStatus.Supported && !string.IsNullOrEmpty(context.CalDavBaseUrl))
                    {
                        <MudTooltip Text="Explore CalDAV Calendars">
                            <MudIconButton Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenCalDavExploreDialog(context))" />
                        </MudTooltip>
                    }
                    @if (_project.M365Settings is not null && !string.IsNullOrEmpty(_project.M365Settings.TenantId))
                    {
                        <MudTooltip Text="Explore M365 Mailbox">
                            <MudIconButton Icon="@Icons.Material.Filled.CloudQueue" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenM365ExploreDialog(context))" />
                        </MudTooltip>
                    }
                    @if (HasSourceAccess(context) && _project.M365Settings is not null && !string.IsNullOrEmpty(_project.M365Settings.TenantId))
                    {
                        <MudTooltip Text="Map Folders">
                            <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenFolderMappingDialog(context))" />
                        </MudTooltip>
                    }
                    @if (context.Status is not MigrationJobStatus.Running and not MigrationJobStatus.Queued)
                    {
                        <MudTooltip Text="@(HasCheckpoints(context) && CanStartMigration(context) ? "Resume / Restart Migration" : GetStartBlockReason(context))">
                            <MudIconButton Icon="@(HasCheckpoints(context) ? Icons.Material.Filled.PlayCircle : Icons.Material.Filled.PlayArrow)" Size="Size.Small"
                                           Color="Color.Success"
                                           Disabled="@(!CanStartMigration(context))"
                                           OnClick="@(() => StartMigration(context))" />
                        </MudTooltip>
                    }
                    @if (context.Status == MigrationJobStatus.Queued)
                    {
                        <MudTooltip Text="Remove from Queue">
                            <MudIconButton Icon="@Icons.Material.Filled.RemoveFromQueue" Size="Size.Small"
                                           Color="Color.Warning"
                                           OnClick="@(() => CancelQueuedJob(context))" />
                        </MudTooltip>
                    }
                    @if (context.Status == MigrationJobStatus.Running)
                    {
                        <MudTooltip Text="Cancel Migration">
                            <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => CancelMigration(context))" />
                        </MudTooltip>
                    }
                    @if (context.Status is MigrationJobStatus.Running or MigrationJobStatus.Queued or MigrationJobStatus.Completed or MigrationJobStatus.Failed or MigrationJobStatus.Cancelled)
                    {
                        <MudTooltip Text="View Logs">
                            <MudIconButton Icon="@Icons.Material.Filled.Description" Size="Size.Small"
                                           Color="Color.Info"
                                           Href="@($"/projects/{ProjectId}/jobs/{context.Id}/logs")" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => OpenEditJobDialog(context))"
                                       Disabled="@(context.Status is MigrationJobStatus.Running or MigrationJobStatus.Queued)" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => OpenDeleteJobDialog(context))"
                                       Disabled="@(context.Status is MigrationJobStatus.Running or MigrationJobStatus.Queued)" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    private Project? _project;
    private List<MigrationJob> _jobs = new();
    private bool _loading = true;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private int _sourceMailboxCount;
    private int _destMailboxCount;
    private bool _isDiscoveringSource;
    private bool _isDiscoveringDest;
    private HubConnection? _hubConnection;
    private HashSet<Guid> _selectedJobs = new();
    private ConcurrencyOverview? _concurrencyOverview;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SetupSignalR();
        }
    }

    private async Task SetupSignalR()
    {
        try
        {
            var hubUrl = Configuration.GetValue<bool>("ReverseProxy:Enabled")
                ? new Uri("http://localhost:8080/hubs/migration-progress")
                : NavigationManager.ToAbsoluteUri("/hubs/migration-progress");

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(hubUrl)
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<Guid, int, int, string?, int, int>("ReceiveProgress", (jobId, processed, total, currentFolder, skipped, duplicates) =>
            {
                var job = _jobs.FirstOrDefault(j => j.Id == jobId);
                if (job is not null)
                {
                    job.ProcessedMessages = processed;
                    job.TotalMessages = total;
                    job.CurrentFolder = currentFolder;
                    job.SkippedMessages = skipped;
                    job.DuplicateMessages = duplicates;
                    InvokeAsync(StateHasChanged);
                }
            });

            _hubConnection.On<Guid, string, string?>("ReceiveStatusChange", async (jobId, status, errorMessage) =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadData();
                    StateHasChanged();
                });
            });

            _hubConnection.On<Guid, int, int, int, int, string?>("ReceiveJobCompleted", async (jobId, processed, total, failed, skipped, errorMessage) =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadData();
                    StateHasChanged();
                });
            });

            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinProject", ProjectId);
        }
        catch (Exception)
        {
            // Hub connection failure should not crash the circuit
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        _project = await ProjectRepository.GetByIdWithConnectorsAsync(ProjectId);

        if (_project is null)
        {
            _loading = false;
            return;
        }

        _jobs = await JobRepository.GetByProjectIdAsync(ProjectId);
        _sourceMailboxCount = _project.DiscoveredMailboxes.Count(m => m.Side == MailboxSide.Source);
        _destMailboxCount = _project.DiscoveredMailboxes.Count(m => m.Side == MailboxSide.Destination);
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Projects", href: "/projects"),
            new(_project.Name, href: null, disabled: true)
        };

        // Concurrency overview for this project
        var tenantId = _project.M365Settings?.TenantId;
        string? sourceKey = null;
        var sourceType = _project.SourceConnectorType;

        if (sourceType == SourceConnectorType.GoogleWorkspace)
        {
            sourceKey = _project.GoogleWorkspaceSettings?.Domain?.ToLowerInvariant();
        }
        else
        {
            // Use IMAP host from first job that has settings
            var firstJobWithImap = _jobs.FirstOrDefault(j => j.ImapSettings?.Host is not null);
            sourceKey = firstJobWithImap?.ImapSettings?.Host?.ToLowerInvariant();
        }

        _concurrencyOverview = LimitService.GetConcurrencyOverview(tenantId, sourceKey, sourceType);

        _loading = false;
    }

    private async Task OpenSourceConnectorDialog()
    {
        var parameters = new DialogParameters
        {
            { nameof(SourceConnectorDialog.Project), _project }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SourceConnectorDialog>("Configure Source", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadData();
    }

    private async Task OpenDestinationConnectorDialog()
    {
        var parameters = new DialogParameters
        {
            { nameof(DestinationConnectorDialog.Project), _project }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<DestinationConnectorDialog>("Configure Destination", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadData();
    }

    private async Task DiscoverSourceMailboxes()
    {
        if (_project?.GoogleWorkspaceSettings is null) return;

        _isDiscoveringSource = true;
        StateHasChanged();

        try
        {
            var gws = _project.GoogleWorkspaceSettings;
            var privateKey = CredentialEncryptor.Decrypt(gws.EncryptedPrivateKey!);

            var discovered = await GoogleDiscovery.DiscoverMailboxesAsync(
                gws.ServiceAccountEmail, privateKey, gws.TokenUri, gws.ImpersonationEmail, gws.Domain);

            var mailboxes = discovered.Select(d => new DiscoveredMailbox
            {
                Email = d.Email,
                DisplayName = d.DisplayName
            }).ToList();

            await DiscoveredMailboxRepository.ReplaceAllAsync(ProjectId, MailboxSide.Source, mailboxes);
            Snackbar.Add($"Discovered {discovered.Count} source mailboxes.", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Discovery failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isDiscoveringSource = false;
            StateHasChanged();
        }
    }

    private async Task DiscoverDestinationMailboxes()
    {
        if (_project?.M365Settings is null) return;

        _isDiscoveringDest = true;
        StateHasChanged();

        try
        {
            var m365 = _project.M365Settings;
            var secret = CredentialEncryptor.Decrypt(m365.EncryptedClientSecret!);

            var discovered = await M365Discovery.DiscoverMailboxesAsync(m365.TenantId!, m365.ClientId!, secret);

            var mailboxes = discovered.Select(d => new DiscoveredMailbox
            {
                Email = d.Email,
                DisplayName = d.DisplayName
            }).ToList();

            await DiscoveredMailboxRepository.ReplaceAllAsync(ProjectId, MailboxSide.Destination, mailboxes);
            Snackbar.Add($"Discovered {discovered.Count} destination mailboxes.", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Discovery failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isDiscoveringDest = false;
            StateHasChanged();
        }
    }

