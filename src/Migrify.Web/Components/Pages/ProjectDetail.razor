    private static bool HasCheckpoints(MigrationJob job) =>
        job.FolderMappings.Any(m => m.LastProcessedUid.HasValue);

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours}h {duration.Minutes}m {duration.Seconds}s";
        if (duration.TotalMinutes >= 1)
            return $"{(int)duration.TotalMinutes}m {duration.Seconds}s";
        return $"{duration.Seconds}s";
    }

    private bool CanStartMigration(MigrationJob job)
    {
        return job.FolderMappings.Any()
            && job.MigrationOptionsConfigured
            && (job.Status is MigrationJobStatus.New or MigrationJobStatus.Ready
                or MigrationJobStatus.Failed or MigrationJobStatus.Cancelled
                or MigrationJobStatus.Completed)
            && HasSourceAccess(job)
            && _project?.M365Settings is not null
            && !string.IsNullOrEmpty(_project.M365Settings.TenantId);
    }

    private void ToggleJobSelection(Guid jobId, bool selected)
    {
        if (selected)
            _selectedJobs.Add(jobId);
        else
            _selectedJobs.Remove(jobId);
    }

    private void ToggleSelectAll(bool selectAll)
    {
        _selectedJobs.Clear();
        if (selectAll)
        {
            foreach (var job in _jobs.Where(CanStartMigration))
                _selectedJobs.Add(job.Id);
        }
    }

    private async Task StartSelectedJobs()
    {
        var jobsToStart = _jobs.Where(j => _selectedJobs.Contains(j.Id) && CanStartMigration(j)).ToList();
        await EnqueueJobs(jobsToStart);
        _selectedJobs.Clear();
    }

    private async Task StartAllJobs()
    {
        var jobsToStart = _jobs.Where(CanStartMigration).ToList();
        await EnqueueJobs(jobsToStart);
    }

    private async Task EnqueueJobs(List<MigrationJob> jobs)
    {
        foreach (var job in jobs)
        {
            var isResume = false;

            if (HasCheckpoints(job))
            {
                var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
                var dialog = await DialogService.ShowAsync<ResumeOrFreshDialog>(
                    $"Resume or Start Fresh? — {job.SourceEmail}", options);
                var result = await dialog.Result;

                if (result is null || result.Canceled)
                    continue;

                var choice = result.Data?.ToString();
                if (choice == "fresh")
                {
                    foreach (var mapping in job.FolderMappings)
                        mapping.LastProcessedUid = null;
                }
                else
                {
                    isResume = true;
                }
            }

            job.Status = MigrationJobStatus.Queued;
            job.ProcessedMessages = 0;
            job.TotalMessages = 0;
            job.SkippedMessages = 0;
            job.DuplicateMessages = 0;
            job.ErrorMessage = null;
            job.CurrentFolder = isResume ? "Queued (resume)..." : "Queued...";
            await JobRepository.UpdateAsync(job);
            await MigrationQueue.EnqueueAsync(job.Id);
        }

        if (jobs.Count > 0)
        {
            Snackbar.Add($"{jobs.Count} job(s) added to queue.", Severity.Success);
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task CancelQueuedJob(MigrationJob job)
    {
        if (MigrationQueue.TryCancelQueued(job.Id))
        {
            job.Status = MigrationJobStatus.Ready;
            job.CurrentFolder = null;
            await JobRepository.UpdateAsync(job);
            Snackbar.Add($"Removed {job.SourceEmail} from queue.", Severity.Info);
            StateHasChanged();
        }
    }

    private static string GetOptionsTooltip(MigrationJob job)
    {
        var parts = new List<string>();
        parts.Add(job.MigrationMode == MigrationMode.Incremental ? "Incremental (skip duplicates)" : "Full Copy");
        parts.Add(job.SkipDuplicates ? "Duplicate check: on" : "Duplicate check: off");
        if (job.DateFrom.HasValue && job.DateTo.HasValue)
            parts.Add($"Date range: {job.DateFrom.Value:dd-MM-yyyy} — {job.DateTo.Value:dd-MM-yyyy}");
        else if (job.DateFrom.HasValue)
            parts.Add($"From: {job.DateFrom.Value:dd-MM-yyyy}");
        else if (job.DateTo.HasValue)
            parts.Add($"Until: {job.DateTo.Value:dd-MM-yyyy}");
        return string.Join(" | ", parts);
    }

    private string GetStartBlockReason(MigrationJob job)
    {
        if (CanStartMigration(job)) return "Start Migration";
        if (!job.FolderMappings.Any()) return "No folder mappings configured";
        if (!job.MigrationOptionsConfigured) return "Migration options not configured";
        if (job.Status == MigrationJobStatus.Running) return "Migration is running";
        if (job.Status == MigrationJobStatus.Queued) return "Job is in queue";
        if (job.Status == MigrationJobStatus.Paused) return "Migration is paused";
        if (!HasSourceAccess(job)) return "Source access not configured";
        if (_project?.M365Settings is null || string.IsNullOrEmpty(_project.M365Settings.TenantId))
            return "M365 destination not configured";
        return "Cannot start migration";
    }

    private async Task StartMigration(MigrationJob job)
    {
        await EnqueueJobs(new List<MigrationJob> { job });
    }

    private async Task CancelMigration(MigrationJob job)
    {
        MigrationQueue.TryCancel(job.Id);
        Snackbar.Add($"Cancellation requested for {job.SourceEmail}.", Severity.Warning);
        await LoadData();
    }

    private static double GetProgressPercent(MigrationJob job)
    {
        if (job.TotalMessages == 0) return 0;
        return (double)job.ProcessedMessages / job.TotalMessages * 100;
    }

