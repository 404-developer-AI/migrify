@page "/not-found"
@attribute [AllowAnonymous]
<PageTitle>Not found - Migrify</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="min-height: 100vh;">
    <MudCard Elevation="0" Style="width: 100%;">
        <MudCardContent Class="pa-8 d-flex flex-column align-center">
            <MudText Typo="Typo.h1" Align="Align.Center" Color="Color.Primary"
                     Style="font-size: 4rem; font-weight: 700; letter-spacing: -0.03em; opacity: 0.3; margin-bottom: 8px;">
                404
            </MudText>
            <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2"
                     Style="font-weight: 700; letter-spacing: -0.01em;">
                Page not found
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center"
                     Style="color: var(--mud-palette-text-secondary);">
                The page you are looking for does not exist.
            </MudText>
            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-6">
                Back to Dashboard
            </MudButton>
        </MudCardContent>
    </MudCard>
</MudContainer>
