@page "/projects"
@attribute [Authorize]
@inject IProjectRepository ProjectRepository
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>Projects - Migrify</PageTitle>

<MudText Typo="Typo.h4" Class="page-title mb-6">Projects</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.Add"
           OnClick="OpenCreateDialog" Class="mb-4">
    New Project
</MudButton>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_projects.Count == 0)
{
    <MudAlert Severity="Severity.Info">
        No projects yet. Click "New Project" to create your first migration project.
    </MudAlert>
}
else
{
    <MudTable Items="_projects" Hover="true" Elevation="0">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Jobs</MudTh>
            <MudTh>Created</MudTh>
            <MudTh Style="width: 100px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudLink Href="@($"/projects/{context.Id}")" Typo="Typo.body1">
                    <strong>@context.Name</strong>
                </MudLink>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.ComputedStatus)">
                    @context.ComputedStatus
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Jobs">
                <MudText Typo="Typo.body2">@context.MigrationJobs.Count</MudText>
            </MudTd>
            <MudTd DataLabel="Created">
                <MudText Typo="Typo.body2">@context.CreatedAt.ToString("dd-MM-yyyy HH:mm")</MudText>
            </MudTd>
            <MudTd>
                <MudTooltip Text="Edit">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   OnClick="@(() => OpenEditDialog(context))" />
                </MudTooltip>
                <MudTooltip Text="Delete">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => OpenDeleteDialog(context))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<Project> _projects = new();
    private bool _loading = true;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
        await SetupSignalR();
    }

    private async Task SetupSignalR()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/migration-progress"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<Guid, string, string?>("ReceiveStatusChange", async (jobId, status, errorMessage) =>
        {
            await InvokeAsync(async () =>
            {
                await LoadProjects();
                StateHasChanged();
            });
        });

        _hubConnection.On<Guid, int, int, int, int, string?>("ReceiveJobCompleted", async (jobId, processed, total, failed, skipped, errorMessage) =>
        {
            await InvokeAsync(async () =>
            {
                await LoadProjects();
                StateHasChanged();
            });
        });

        await _hubConnection.StartAsync();
        await _hubConnection.InvokeAsync("JoinDashboard");
    }

    private async Task LoadProjects()
    {
        _loading = true;
        _projects = await ProjectRepository.GetAllAsync();
        _loading = false;
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ProjectDialog>("New Project", options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadProjects();
    }

    private async Task OpenEditDialog(Project project)
    {
        var parameters = new DialogParameters
        {
            { nameof(ProjectDialog.ExistingProject), project }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ProjectDialog>("Edit Project", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadProjects();
    }

    private async Task OpenDeleteDialog(Project project)
    {
        var parameters = new DialogParameters
        {
            { nameof(DeleteConfirmationDialog.ProjectName), project.Name }
        };

        var dialog = await DialogService.ShowAsync<DeleteConfirmationDialog>("Delete Project", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await ProjectRepository.DeleteAsync(project.Id);
            Snackbar.Add($"Project '{project.Name}' deleted.", Severity.Success);
            await LoadProjects();
        }
    }

    private static Color GetStatusColor(ProjectStatus status) => status switch
    {
        ProjectStatus.New => Color.Info,
        ProjectStatus.Active => Color.Warning,
        ProjectStatus.Completed => Color.Success,
        _ => Color.Default
    };

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.DisposeAsync();
            }
            catch { }
        }
    }
}
