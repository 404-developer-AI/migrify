@page "/Error"
@using System.Diagnostics
@attribute [AllowAnonymous]

<PageTitle>Error - Migrify</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="min-height: 100vh;">
    <MudCard Elevation="0" Style="width: 100%;">
        <MudCardContent Class="pa-8 d-flex flex-column align-center">
            <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Color="Color.Error"
                     Style="font-size: 56px; margin-bottom: 16px;" />
            <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2"
                     Style="font-weight: 700; letter-spacing: -0.01em;">
                Something went wrong
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center"
                     Style="color: var(--mud-palette-text-secondary); margin-bottom: 8px;">
                An unexpected error occurred while processing your request.
            </MudText>
            @if (ShowRequestId)
            {
                <MudText Typo="Typo.caption" Align="Align.Center"
                         Style="color: var(--mud-palette-text-disabled); margin-bottom: 16px;">
                    Request ID: @RequestId
                </MudText>
            }
            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
                Back to Dashboard
            </MudButton>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
