@page "/Error"
@using System.Diagnostics
@attribute [AllowAnonymous]

<PageTitle>Error - Migrify</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="min-height: 100vh;">
    <MudCard Class="pa-4" Style="width: 100%;">
        <MudCardContent>
            <MudText Typo="Typo.h4" Color="Color.Error" Align="Align.Center" Class="mb-4">An error occurred</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center">
                An unexpected error occurred while processing your request.
            </MudText>
            @if (ShowRequestId)
            {
                <MudText Typo="Typo.caption" Align="Align.Center" Class="mt-4">
                    Request ID: @RequestId
                </MudText>
            }
            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4">
                Back to Dashboard
            </MudButton>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
