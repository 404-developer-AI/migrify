@page "/settings"
@attribute [Authorize]

<PageTitle>Settings - Migrify</PageTitle>

<MudText Typo="Typo.h4" Class="page-title mb-6">Settings</MudText>

<MudCard Elevation="0">
    <MudCardContent>
        <MudAlert Severity="Severity.Info" Class="mb-4">
            Settings will be available in a future version.
        </MudAlert>
        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
            Here you will be able to manage application settings.
        </MudText>
    </MudCardContent>
</MudCard>
