@page "/account/login"
@layout LoginLayout
@attribute [AllowAnonymous]

<PageTitle>Sign in - Migrify</PageTitle>

<div class="login-card">
    <div style="text-align: center; margin-bottom: 32px;">
        <MudIcon Icon="@Icons.Material.Outlined.SwapHoriz"
                 Style="font-size: 40px; color: white;" />
        <h1 class="login-title">Migrify</h1>
        <p class="login-subtitle">Sign in to your account</p>
    </div>

    @if (_hasError)
    {
        <div class="login-error">
            Invalid credentials. Please try again.
        </div>
    }

    <form method="post" action="/api/account/login">
        <AntiforgeryToken />

        <div style="margin-bottom: 20px;">
            <label for="email" class="login-label">Email address</label>
            <input type="email" id="email" name="_loginModel.Email"
                   class="login-input" placeholder="you@company.com" required />
        </div>

        <div style="margin-bottom: 28px;">
            <label for="password" class="login-label">Password</label>
            <input type="password" id="password" name="_loginModel.Password"
                   class="login-input" placeholder="Enter your password" required />
        </div>

        <button type="submit" class="login-button">
            Sign in
        </button>
    </form>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }

    private bool _hasError => !string.IsNullOrEmpty(Error);
}
